FROM node:20-slim

# Install build tools for native modules (better-sqlite3)
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY backend/package.json ./
RUN npm install

COPY backend/ ./

RUN mkdir -p data

EXPOSE 3001

CMD ["sh", "-c", "node seed.js && node src/index.js"]
